{ border-color: red !important; }

input[type=3D"text"], input[type=3D"password"], input[type=3D"number"], tex=
tarea, select, label.button { box-sizing: border-box; padding: 4px 8px; bor=
der-radius: 8px; border-width: 1px; border-style: solid; font-size: 16px; f=
ont-style: normal; font-weight: 500; line-height: 22px; }

input[type=3D"text"]:focus, input[type=3D"password"]:focus, input[type=3D"n=
umber"]:focus, textarea:focus, select:focus, label.button:focus { outline: =
2px solid var(--primary-color, var(--focus-outline-color)); }

input[type=3D"checkbox"], input[type=3D"radio"] { padding: 8px; }

input[type=3D"checkbox"]:focus, input[type=3D"radio"]:focus { outline: 2px =
solid var(--primary-color, var(--focus-outline-color)); outline-offset: 2px=
; box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--primary-color, var(--focus-ou=
tline-color)); }

input[type=3D"range"] { appearance: none; }

input[type=3D"range"]::-webkit-slider-runnable-track { width: 300px; height=
: 5px; border: none; border-radius: 3px; }

input[type=3D"range"]::-webkit-slider-thumb { appearance: none; border: non=
e; height: 16px; width: 16px; border-radius: 50%; margin-top: -5px; }

input[type=3D"range"]:focus { outline: 2px solid var(--primary-color, var(-=
-focus-outline-color)); }

input[type=3D"submit"]:disabled, input[type=3D"button"]:disabled, button:di=
sabled, label.button:disabled { opacity: 0.6; cursor: default; }

input[data-val-required] + span::before, input.required + span::before, sel=
ect.required + span::before { content: " * "; }

