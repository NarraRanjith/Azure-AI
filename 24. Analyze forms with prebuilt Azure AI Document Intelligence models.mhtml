f?v=3D1") format("truetype"); }

body, html { font-family: theme-font, sans-serif; font-size: 14px; padding:=
 0px; margin: 0px; overflow: hidden; -webkit-font-smoothing: antialiased; }

.instructions-client.integrated-layout { margin-left: 2px; }

